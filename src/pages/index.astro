---
import Base from '../layouts/Base.astro';
import Demo from '../components/Demo.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const shot1 = `${base}/assets/shot-1.png`;
const shot2 = `${base}/assets/shot-2.png`;
const shot3 = `${base}/assets/shot-3.png`;
---
<Base
  title="Pinpoint - comment on any live page, hand off to your AI agent"
  description="Point at any element on a running site, leave a comment, and hand off an agent-ready Markdown brief to ChatGPT, Claude, Cursor, or Copilot. Nothing leaves your machine."
>
  <!-- Hero -->
  <header id="top" class="pt-[72px] pb-14">
    <div class="w-full max-w-[1180px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-[0.92fr_1.08fr] gap-12 lg:gap-14 items-center">
      <div>
        <span class="inline-flex items-center gap-2 text-[12.5px] text-muted px-3 py-[5px] border border-line rounded-full bg-bg2 mb-[22px]">
          <span class="w-1.5 h-1.5 rounded-full bg-accentSoft"></span> Comments never leave your browser
        </span>
        <h1 class="text-[clamp(34px,5vw,54px)] leading-[1.04] tracking-[-0.03em] font-bold">
          Comment on any live page.<br /><span class="text-accentSoft">Hand off</span> to your AI agent.
        </h1>
        <p class="mt-5 text-[17px] text-muted max-w-[30em]">Point at any element on a running site, leave a comment, and export the whole batch as an agent-ready Markdown brief for ChatGPT, Claude, Cursor, or Copilot.</p>
        <div class="mt-[30px] flex flex-wrap gap-3 items-center">
          <a href="#install" class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-2.5 rounded-full bg-accent text-white hover:bg-accentSoft active:translate-y-px transition">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            Add to Chrome
          </a>
          <a href="#demo" class="inline-flex items-center text-sm font-semibold px-4 py-2.5 rounded-full border border-lineStrong text-ink hover:bg-white/5 active:translate-y-px transition">Try the live demo</a>
        </div>
        <p class="mt-4 text-[13px] text-faint">Free. Works on Chrome and Firefox. No account, no servers.</p>
      </div>

      <Demo />
    </div>
  </header>

  <main>
    <!-- How it works: text first, supporting preview below -->
    <section id="how" class="py-[84px] border-t border-line">
      <div class="w-full max-w-[1180px] mx-auto px-6">
        <div class="max-w-[34em] mb-11">
          <h2 class="text-[clamp(26px,3.4vw,38px)] tracking-[-0.025em] leading-[1.1]">Review live pages the way you think</h2>
          <p class="mt-3.5 text-muted text-base">No screenshots pasted into chat, no "the button near the top right". Pinpoint captures the exact element and your intent.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-9 md:gap-7">
          <div>
            <span class="inline-flex items-center justify-center w-[26px] h-[26px] rounded-full bg-accent/15 text-accentSoft font-bold text-[13px] mb-2">1</span>
            <h3 class="text-[17px] tracking-[-0.01em] font-semibold">Point and comment</h3>
            <p class="mt-1.5 text-muted text-[14.5px] mb-4">Hover to highlight, click to attach a comment to that exact element, right on the page.</p>
            <div class="rounded-[14px] border border-line overflow-hidden bg-panel aspect-[16/10]"><img src={shot1} alt="Picking an element and commenting" loading="lazy" class="w-full h-full object-cover object-top block" /></div>
          </div>
          <div>
            <span class="inline-flex items-center justify-center w-[26px] h-[26px] rounded-full bg-accent/15 text-accentSoft font-bold text-[13px] mb-2">2</span>
            <h3 class="text-[17px] tracking-[-0.01em] font-semibold">Collect a batch</h3>
            <p class="mt-1.5 text-muted text-[14.5px] mb-4">Numbered pins stay anchored to their elements. Every comment lands in one panel as you go.</p>
            <div class="rounded-[14px] border border-line overflow-hidden bg-panel aspect-[16/10]"><img src={shot2} alt="All comments in one panel with numbered pins" loading="lazy" class="w-full h-full object-cover object-top block" /></div>
          </div>
          <div>
            <span class="inline-flex items-center justify-center w-[26px] h-[26px] rounded-full bg-accent/15 text-accentSoft font-bold text-[13px] mb-2">3</span>
            <h3 class="text-[17px] tracking-[-0.01em] font-semibold">Hand off the brief</h3>
            <p class="mt-1.5 text-muted text-[14.5px] mb-4">One click turns the batch into a structured Markdown brief, ready to paste into your agent.</p>
            <div class="rounded-[14px] border border-line overflow-hidden bg-panel aspect-[16/10]"><img src={shot3} alt="Hand off a structured brief" loading="lazy" class="w-full h-full object-cover object-top block" /></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features split -->
    <section id="features" class="py-[84px] border-t border-line">
      <div class="w-full max-w-[1180px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-16 items-center">
        <div>
          <div class="max-w-[34em] mb-7">
            <h2 class="text-[clamp(26px,3.4vw,38px)] tracking-[-0.025em] leading-[1.1]">More than a comment box</h2>
            <p class="mt-3.5 text-muted text-base">Everything you need to describe a change precisely, without leaving the page.</p>
          </div>
          <ul class="list-none flex flex-col">
            <li class="py-4 first:pt-0 border-b border-line last:border-b-0 flex gap-3.5 items-start">
              <span class="shrink-0 w-[34px] h-[34px] rounded-[9px] bg-accent/15 text-accentSoft flex items-center justify-center"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path d="m13 13 6 6"/><path d="M3 3l7 17 2.5-7.5L20 10z"/></svg></span>
              <div><h4 class="text-[15.5px] font-semibold">Component detection</h4><p class="text-muted text-sm mt-0.5">Resolves React, Vue, and Svelte component names and source files when they are available.</p></div>
            </li>
            <li class="py-4 first:pt-0 border-b border-line last:border-b-0 flex gap-3.5 items-start">
              <span class="shrink-0 w-[34px] h-[34px] rounded-[9px] bg-accent/15 text-accentSoft flex items-center justify-center"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M15 3v18"/></svg></span>
              <div><h4 class="text-[15.5px] font-semibold">Measure and inspect</h4><p class="text-muted text-sm mt-0.5">Check spacing, sample a color, and read typography (size, line-height, weight, Tailwind utility).</p></div>
            </li>
            <li class="py-4 first:pt-0 border-b border-line last:border-b-0 flex gap-3.5 items-start">
              <span class="shrink-0 w-[34px] h-[34px] rounded-[9px] bg-accent/15 text-accentSoft flex items-center justify-center"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3z"/><circle cx="12" cy="13" r="3"/></svg></span>
              <div><h4 class="text-[15.5px] font-semibold">Annotated screenshots</h4><p class="text-muted text-sm mt-0.5">Capture an element and mark it up with arrows, text, blur, and numbered counters before attaching.</p></div>
            </li>
            <li class="py-4 first:pt-0 border-b border-line last:border-b-0 flex gap-3.5 items-start">
              <span class="shrink-0 w-[34px] h-[34px] rounded-[9px] bg-accent/15 text-accentSoft flex items-center justify-center"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path d="M7 8h10"/><path d="M7 12h10"/><path d="M7 16h6"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg></span>
              <div><h4 class="text-[15.5px] font-semibold">Numbered, stacked pins</h4><p class="text-muted text-sm mt-0.5">Several notes on one element stack into a single pin that fans out on hover.</p></div>
            </li>
          </ul>
        </div>
        <div class="rounded-[14px] border border-lineStrong overflow-hidden shadow-shot"><img src={shot2} alt="Pinpoint panel with numbered comments" loading="lazy" class="w-full block" /></div>
      </div>
    </section>

    <!-- Privacy band -->
    <section class="py-[84px] border-t border-line">
      <div class="w-full max-w-[1180px] mx-auto px-6 text-center">
        <span class="inline-flex items-center justify-center w-[46px] h-[46px] rounded-xl bg-accent/15 text-accentSoft mb-[22px]"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
        <h2 class="text-[clamp(26px,3.4vw,36px)] tracking-[-0.025em]">Nothing leaves your machine</h2>
        <p class="max-w-[36em] mx-auto mt-4 text-muted text-base">Pinpoint has no servers, no analytics, and no account. Comments live in your browser's local storage, scoped per site. Screenshots save to your own Downloads folder.</p>
        <div class="mt-[30px] flex justify-center">
          <a href={`${base}/privacy/`} class="inline-flex items-center text-sm font-semibold px-4 py-2.5 rounded-full border border-lineStrong text-ink hover:bg-white/5 active:translate-y-px transition">Read the privacy policy</a>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section id="install" class="py-24 text-center">
      <div class="w-full max-w-[1180px] mx-auto px-6">
        <h2 class="text-[clamp(28px,4vw,44px)] tracking-[-0.03em] leading-[1.08]">Start reviewing in seconds</h2>
        <p class="text-muted mt-4 mx-auto max-w-[30em] text-base">Add Pinpoint, turn it on for a site, and point at the first thing you want to change.</p>
        <div class="mt-[30px] flex flex-wrap gap-3 justify-center">
          <a href="#" class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-2.5 rounded-full bg-accent text-white hover:bg-accentSoft active:translate-y-px transition">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="9"/><path d="M12 3v9l6 3"/></svg>
            Add to Chrome
          </a>
          <a href="https://github.com/TamirAssayag/pinpoint" class="inline-flex items-center text-sm font-semibold px-4 py-2.5 rounded-full border border-lineStrong text-ink hover:bg-white/5 active:translate-y-px transition">View on GitHub</a>
        </div>
        <p class="mt-[18px] text-[13px] text-faint">Chrome Web Store listing coming soon. Star the repo to follow along.</p>
      </div>
    </section>
  </main>
</Base>
