---
// Interactive product demo: Comment / Measure / Color / Inspect on a mock page.
// Fixed height so interacting never resizes the hero; the brief slides up as an overlay.
---
<div id="demo" class="relative flex flex-col h-[560px] rounded-[14px] border border-lineStrong shadow-demo overflow-hidden [background:linear-gradient(180deg,#151925,#0f1219)]">
  <div class="flex items-center gap-2.5 px-3 py-2.5 border-b border-line bg-white/[0.02]">
    <div id="tools" class="flex items-center gap-0.5 bg-bg2 border border-line rounded-[9px] p-0.5">
      <button data-tool="comment" type="button" class="tool-btn text-[12px] font-semibold rounded-[7px] px-2.5 py-[5px] transition">Comment</button>
      <button data-tool="measure" type="button" class="tool-btn text-[12px] font-semibold rounded-[7px] px-2.5 py-[5px] transition">Measure</button>
      <button data-tool="color" type="button" class="tool-btn text-[12px] font-semibold rounded-[7px] px-2.5 py-[5px] transition">Color</button>
      <button data-tool="inspect" type="button" class="tool-btn text-[12px] font-semibold rounded-[7px] px-2.5 py-[5px] transition">Inspect</button>
    </div>
    <span class="flex-1"></span>
    <button id="demo-reset" type="button" class="text-xs font-semibold text-muted bg-transparent border border-line rounded-[7px] px-2.5 py-[5px] hover:text-ink hover:border-lineStrong transition">Reset</button>
    <button id="demo-handoff" type="button" disabled class="text-xs font-semibold text-white bg-accent border border-accent rounded-[7px] px-2.5 py-[5px] hover:bg-accentSoft disabled:opacity-40 disabled:cursor-not-allowed transition">Hand off</button>
  </div>
  <div id="hint" class="shrink-0 px-4 py-[7px] text-[11.5px] text-faint border-b border-line bg-bg2/40">Click any element to attach a comment.</div>

  <div class="relative flex-1 min-h-0">
    <div id="stage" class="relative h-full px-6 pt-[26px] pb-[30px] overflow-hidden [background:radial-gradient(120%_80%_at_50%_-10%,rgba(42,79,214,.10),transparent_60%),#0a0c11]">
      <div class="flex items-center gap-[18px] pb-4 border-b border-line">
        <span data-sel="span.brand-logo" class="font-bold text-[15px] cursor-crosshair rounded-md transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10">Northwind</span>
        <span data-sel="a.nav-pricing" class="text-[13px] text-muted cursor-crosshair rounded-md transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10">Pricing</span>
        <span data-sel="a.nav-docs" class="text-[13px] text-muted cursor-crosshair rounded-md transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10">Docs</span>
        <span data-sel="button.signup" class="ml-auto text-[12.5px] font-semibold bg-white text-[#111] px-[13px] py-[7px] rounded-[7px] cursor-crosshair transition hover:ring-2 hover:ring-accentSoft">Get started</span>
      </div>
      <div class="pt-[26px] pb-2">
        <div data-sel="h1.page-hero" class="text-[27px] font-bold tracking-[-0.02em] leading-[1.12] max-w-[12em] cursor-crosshair rounded-md transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10">Ship the dashboard your customers asked for</div>
        <div data-sel="p.hero-sub" class="mt-2.5 text-muted text-sm max-w-[26em] cursor-crosshair rounded-md transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10">A faster way to track usage, billing, and team activity in one place.</div>
        <div class="mt-5 grid grid-cols-2 gap-3">
          <div data-sel="div.metric-mrr" class="border border-line rounded-[10px] p-3.5 bg-bg2 cursor-crosshair transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10"><div class="text-[11px] uppercase tracking-[0.08em] text-faint">MRR</div><div class="mt-1.5 text-[13px] text-muted">$48,210</div></div>
          <div data-sel="div.metric-churn" class="border border-line rounded-[10px] p-3.5 bg-bg2 cursor-crosshair transition hover:ring-2 hover:ring-accentSoft hover:bg-accent/10"><div class="text-[11px] uppercase tracking-[0.08em] text-faint">Churn</div><div class="mt-1.5 text-[13px] text-muted">2.4% this month</div></div>
        </div>
      </div>
    </div>
    <svg id="ov-svg" class="absolute inset-0 w-full h-full pointer-events-none z-[5]"></svg>
    <div id="ov" class="absolute inset-0 pointer-events-none z-[6]"></div>
    <div id="sel-label" class="absolute z-[7] -translate-y-full font-mono text-[11px] text-white bg-accent px-[7px] py-0.5 rounded-[5px_5px_5px_0] pointer-events-none whitespace-nowrap opacity-0 transition-opacity"></div>
  </div>

  <div class="shrink-0 h-[178px] flex flex-col border-t border-line bg-white/[0.02]">
    <div class="shrink-0 flex items-center gap-2 px-4 pt-3 pb-1.5 text-[12.5px] text-muted"><span id="c-count" class="text-ink font-semibold">0</span> comments collected</div>
    <div class="flex-1 min-h-0 overflow-y-auto">
      <ul id="c-list" class="list-none px-3 pb-3 flex flex-col gap-2"></ul>
      <div id="c-empty" class="px-4 pt-2 pb-[18px] text-[13px] text-faint">Hover the page above, then click an element to drop a comment.</div>
    </div>
  </div>

  <div id="brief" class="absolute inset-x-0 bottom-0 z-[8] h-[72%] flex flex-col bg-panel2 border-t border-lineStrong shadow-[0_-20px_50px_rgba(0,0,0,.45)] translate-y-full transition-transform duration-300 motion-reduce:transition-none">
    <div class="shrink-0 flex items-center justify-between px-3.5 py-[11px] border-b border-line">
      <span class="text-[12.5px] text-accentSoft">Agent-ready brief</span>
      <button id="brief-close" type="button" class="text-xs font-semibold text-muted bg-transparent border border-line rounded-[7px] px-2.5 py-[5px] hover:text-ink hover:border-lineStrong transition">Close</button>
    </div>
    <pre id="brief-pre" class="m-0 flex-1 min-h-0 overflow-y-auto px-4 py-3 font-mono text-xs leading-relaxed text-muted whitespace-pre-wrap break-words"></pre>
  </div>
</div>

<script>
  function initDemo() {
    var stage = document.getElementById('stage');
    var ov = document.getElementById('ov');
    var svg = document.getElementById('ov-svg');
    var label = document.getElementById('sel-label');
    var list = document.getElementById('c-list');
    var empty = document.getElementById('c-empty');
    var count = document.getElementById('c-count');
    var handoffBtn = document.getElementById('demo-handoff');
    var resetBtn = document.getElementById('demo-reset');
    var brief = document.getElementById('brief');
    var briefPre = document.getElementById('brief-pre');
    var hint = document.getElementById('hint');
    var toolsEl = document.getElementById('tools');
    if (!stage) return;

    var SVGNS = 'http://www.w3.org/2000/svg';
    var samples = [
      'Tighten this headline, it is too generic.',
      'Use the brand blue here, not the default.',
      'This number should be live, not hard-coded.',
      'Add more padding, the card feels cramped.',
      'Make this the primary action.'
    ];
    var hints = {
      comment: 'Click any element to attach a comment.',
      measure: 'Click two elements to measure the gap between them.',
      color: 'Click any element to sample its color.',
      inspect: 'Click any text to read its typography.'
    };

    var tool = 'comment';
    var comments = [];
    var marks = [];
    var measureA = null;
    var targets = Array.prototype.slice.call(stage.querySelectorAll('[data-sel]'));

    function rectOf(el) {
      var s = stage.getBoundingClientRect(), r = el.getBoundingClientRect();
      return { left: r.left - s.left, top: r.top - s.top, right: r.right - s.left, w: r.width, h: r.height };
    }
    function topRight(el) { var r = rectOf(el); return { left: r.right, top: r.top }; }
    function center(el) { var r = rectOf(el); return { left: r.left + r.w / 2, top: r.top + r.h / 2 }; }
    function clearTransient() { marks.forEach(function (m) { m.remove(); }); marks = []; svg.innerHTML = ''; measureA = null; }
    function txt(s) { var n = document.createElement('span'); n.textContent = s; return n; }
    function rgbToHex(str) {
      var m = (str || '').match(/(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
      if (!m) return str;
      function h(x) { return ('0' + parseInt(x, 10).toString(16)).slice(-2); }
      return ('#' + h(m[1]) + h(m[2]) + h(m[3])).toUpperCase();
    }
    function chip(el, nodes) {
      var p = rectOf(el);
      var c = document.createElement('div');
      c.className = 'absolute z-[6] -translate-y-full flex items-center gap-1.5 font-mono text-[11px] text-ink bg-panel2 border border-lineStrong rounded-[6px] px-2 py-1 shadow-lg whitespace-nowrap';
      c.style.left = p.left + 'px';
      c.style.top = (p.top - 4) + 'px';
      nodes.forEach(function (n) { c.appendChild(n); });
      ov.appendChild(c); marks.push(c);
    }

    targets.forEach(function (el) {
      el.addEventListener('mouseenter', function () {
        var p = rectOf(el);
        label.textContent = el.dataset.sel;
        label.style.left = p.left + 'px';
        label.style.top = (p.top - 3) + 'px';
        label.classList.remove('opacity-0');
        label.classList.add('opacity-100');
      });
      el.addEventListener('mouseleave', function () {
        label.classList.add('opacity-0');
        label.classList.remove('opacity-100');
      });
      el.addEventListener('click', function (e) {
        e.preventDefault();
        if (tool === 'comment') addComment(el);
        else if (tool === 'inspect') inspectEl(el);
        else if (tool === 'color') colorEl(el);
        else if (tool === 'measure') measureEl(el);
      });
    });

    function addComment(el) {
      var n = comments.length + 1;
      var c = { n: n, sel: el.dataset.sel, text: samples[(n - 1) % samples.length] };
      comments.push(c);

      var p = topRight(el);
      var pin = document.createElement('div');
      pin.className = 'absolute z-[7] w-6 h-6 flex items-center justify-center text-white bg-accent border-[1.5px] border-bg rounded-teardrop text-xs font-bold shadow-lg -translate-x-1/2 -translate-y-1/2 animate-pop motion-reduce:animate-none';
      pin.textContent = String(n);
      pin.style.left = p.left + 'px';
      pin.style.top = p.top + 'px';
      stage.appendChild(pin);
      c.pin = pin;

      var li = document.createElement('li');
      li.className = 'flex gap-2.5 items-start';
      var num = document.createElement('span');
      num.className = 'shrink-0 w-5 h-5 mt-[7px] rounded-teardrop bg-accent text-white text-[11px] font-bold flex items-center justify-center';
      num.textContent = String(n);
      var body = document.createElement('div');
      body.className = 'flex-1 min-w-0';
      var sel = document.createElement('div');
      sel.className = 'font-mono text-[11px] text-accentSoft';
      sel.textContent = c.sel;
      var input = document.createElement('input');
      input.className = 'w-full mt-0.5 font-sans text-[13px] text-ink bg-panel2 border border-line rounded-[7px] px-2.5 py-1.5 focus:outline-none focus:border-accentSoft';
      input.value = c.text;
      input.setAttribute('aria-label', 'Comment for ' + c.sel);
      input.addEventListener('input', function () { c.text = input.value; });
      body.appendChild(sel);
      body.appendChild(input);
      li.appendChild(num);
      li.appendChild(body);
      list.appendChild(li);

      empty.style.display = 'none';
      count.textContent = String(comments.length);
      handoffBtn.disabled = false;
      brief.classList.add('translate-y-full');
    }

    function inspectEl(el) {
      clearTransient();
      var cs = getComputedStyle(el);
      var size = Math.round(parseFloat(cs.fontSize));
      var lhRaw = parseFloat(cs.lineHeight);
      var lh = isNaN(lhRaw) ? Math.round(size * 1.2) : Math.round(lhRaw);
      chip(el, [txt(size + '/' + lh + 'px'), txt('·'), txt(cs.fontWeight)]);
    }

    function colorEl(el) {
      clearTransient();
      var cs = getComputedStyle(el);
      var col = cs.backgroundColor;
      if (col === 'rgba(0, 0, 0, 0)' || col === 'transparent') col = cs.color;
      var sw = document.createElement('span');
      sw.className = 'inline-block w-3 h-3 rounded-[3px] border border-white/20';
      sw.style.background = col;
      chip(el, [sw, txt(rgbToHex(col))]);
    }

    function dot(pt) {
      var d = document.createElement('div');
      d.className = 'absolute z-[6] w-2.5 h-2.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-accentSoft border-2 border-bg';
      d.style.left = pt.left + 'px';
      d.style.top = pt.top + 'px';
      ov.appendChild(d); marks.push(d);
    }
    function measureEl(el) {
      var c = center(el);
      if (!measureA) { clearTransient(); measureA = c; dot(c); return; }
      var a = measureA, b = c;
      var ln = document.createElementNS(SVGNS, 'line');
      ln.setAttribute('x1', a.left); ln.setAttribute('y1', a.top);
      ln.setAttribute('x2', b.left); ln.setAttribute('y2', b.top);
      ln.setAttribute('stroke', '#4f6ef0'); ln.setAttribute('stroke-width', '2'); ln.setAttribute('stroke-dasharray', '5 4');
      svg.appendChild(ln);
      dot(b);
      var dist = Math.round(Math.hypot(b.left - a.left, b.top - a.top));
      var lab = document.createElement('div');
      lab.className = 'absolute z-[6] -translate-x-1/2 -translate-y-1/2 font-mono text-[11px] font-semibold text-white bg-accent rounded-[5px] px-1.5 py-0.5 shadow-lg whitespace-nowrap';
      lab.textContent = dist + ' px';
      lab.style.left = ((a.left + b.left) / 2) + 'px';
      lab.style.top = ((a.top + b.top) / 2) + 'px';
      ov.appendChild(lab); marks.push(lab);
      measureA = null;
    }

    function setTool(t) {
      tool = t;
      Array.prototype.forEach.call(toolsEl.querySelectorAll('.tool-btn'), function (b) {
        var on = b.dataset.tool === t;
        b.classList.toggle('bg-accent', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('text-muted', !on);
      });
      hint.textContent = hints[t];
      clearTransient();
    }
    Array.prototype.forEach.call(toolsEl.querySelectorAll('.tool-btn'), function (b) {
      b.addEventListener('click', function () { setTool(b.dataset.tool); });
    });

    handoffBtn.addEventListener('click', function () {
      if (!comments.length) return;
      var md = comments.map(function (c) {
        return '## ' + c.n + '. ' + c.sel + '\n- Page: northwind.app/dashboard\n- Comment: ' + (c.text || '').trim();
      }).join('\n\n');
      briefPre.textContent = md;
      brief.classList.remove('translate-y-full');
    });
    document.getElementById('brief-close').addEventListener('click', function () {
      brief.classList.add('translate-y-full');
    });

    resetBtn.addEventListener('click', function () {
      comments.forEach(function (c) { if (c.pin) c.pin.remove(); });
      comments = [];
      list.innerHTML = '';
      empty.style.display = '';
      count.textContent = '0';
      handoffBtn.disabled = true;
      brief.classList.add('translate-y-full');
      clearTransient();
    });

    window.addEventListener('resize', function () {
      comments.forEach(function (c) {
        var el = targets.filter(function (t) { return t.dataset.sel === c.sel; })[0];
        if (el && c.pin) { var p = topRight(el); c.pin.style.left = p.left + 'px'; c.pin.style.top = p.top + 'px'; }
      });
      clearTransient();
    });

    setTool('comment');
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initDemo);
  else initDemo();
</script>
